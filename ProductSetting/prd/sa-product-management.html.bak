            <!-- VCC Bin 配置页面（添加/编辑） -->
            <div id="vcc-bin-config" class="page hidden">
                <div class="page-header">
                    <div class="page-title" id="binConfigTitle">添加 Bin 配置</div>
                    <div class="page-desc">配置该 Bin 下的所有属性</div>
                </div>

                <div class="action-bar">
                    <button class="btn btn-default" onclick="backToBinList()">← 返回 Bin 列表</button>
                    <div></div>
                </div>

                <!-- 步骤导航 -->
                <div class="steps">
                    <div class="step active">
                        <div class="step-number">1</div>
                        <div class="step-title">基本信息</div>
                    </div>
                    <div class="step">
                        <div class="step-number">2</div>
                        <div class="step-title">卡账户能力</div>
                    </div>
                    <div class="step">
                        <div class="step-number">3</div>
                        <div class="step-title">交易能力</div>
                    </div>
                    <div class="step">
                        <div class="step-number">4</div>
                        <div class="step-title">卡限制配置</div>
                    </div>
                    <div class="step">
                        <div class="step-number">5</div>
                        <div class="step-title">风控能力</div>
                    </div>
                    <div class="step">
                        <div class="step-number">6</div>
                        <div class="step-title">持卡人要求</div>
                    </div>
                </div>

                <form id="vccBinForm">
                    <!-- 步骤 1: 基本信息 -->
                    <div class="step-content active" data-step="1">
                        <div class="card">
                            <div class="card-title">1. 卡 Bin 基本信息</div>
                            
                            <div class="bin-item" data-bin-index="1">
                                <!-- 1.1 卡 Bin 基本信息 -->
                                <div class="form-section">
                                    <div class="form-section-title">1.1 卡 Bin 基本信息</div>
                                    
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>卡 Bin
                                                <span class="label-en">bin</span>
                                            </label>
                                            <input type="text" class="form-control" placeholder="如：53422618" maxlength="8" required>
                                            <div class="form-hint">6～8位卡Bin号码（当前主流为8位）</div>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>卡组织
                                                <span class="label-en">card-scheme</span>
                                            </label>
                                            <select class="form-control" required>
                                                <option value="">请选择</option>
                                                <option value="Visa">Visa</option>
                                                <option value="Mastercard">Mastercard</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">
                                            <span class="required">*</span>Bin 描述
                                            <span class="label-en">bin description</span>
                                        </label>
                                        <div class="subsection" style="background: #fafafa; padding: 16px; border-radius: 4px;">
                                            <div class="form-group" style="margin-bottom: 16px;">
                                                <label style="display: block; margin-bottom: 8px; font-weight: 500; font-size: 13px;">
                                                    <span class="required">*</span>简体中文 (zh-CN)
                                                </label>
                                                <textarea class="form-control" rows="3" placeholder="第1行：适用场景描述（不超过50字符）&#10;第2行：支持的平台或功能（不超过50字符）&#10;第3行：限额或其他特点（不超过50字符，可选）" required style="resize: vertical;"></textarea>
                                                <div class="form-hint">2-3行，每行不超过50个字符</div>
                                            </div>
                                            <div class="form-group" style="margin-bottom: 16px;">
                                                <label style="display: block; margin-bottom: 8px; font-weight: 500; font-size: 13px;">
                                                    <span class="required">*</span>英文 (en-US)
                                                </label>
                                                <textarea class="form-control" rows="3" placeholder="Line 1: Scenario description (max 100 chars)&#10;Line 2: Supported platforms or features (max 100 chars)&#10;Line 3: Limits or other features (max 100 chars, optional)" required style="resize: vertical;"></textarea>
                                                <div class="form-hint">2-3 lines, max 100 characters per line</div>
                                            </div>
                                            <div class="form-group" style="margin-bottom: 0;">
                                                <label style="display: block; margin-bottom: 8px; font-weight: 500; font-size: 13px;">
                                                    粤语 (zh-HK)
                                                </label>
                                                <textarea class="form-control" rows="3" placeholder="第1行：適用場景描述（唔超過50字符）&#10;第2行：支持嘅平台或功能（唔超過50字符）&#10;第3行：限額或其他特點（唔超過50字符，可選）" style="resize: vertical;"></textarea>
                                                <div class="form-hint">2-3行，每行唔超過50個字符（可選）</div>
                                            </div>
                                        </div>
                                        <div class="form-hint" style="margin-top: 8px;">
                                            <strong>示例：</strong><br>
                                            简体中文：适用于广告投放场景的企业虚拟卡 / 支持 Google Ads、Facebook Ads 等主流广告平台 / 单笔限额 50,000 USD，适合大额广告投放<br>
                                            英文：Corporate virtual card for advertising scenarios / Supports major platforms like Google Ads, Facebook Ads / Transaction limit: 50,000 USD per transaction<br>
                                            粤语：適用於廣告投放場景嘅企業虛擬卡 / 支持 Google Ads、Facebook Ads 等主流廣告平台 / 單筆限額 50,000 USD，適合大額廣告投放
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>发卡地区
                                                <span class="label-en">region</span>
                                            </label>
                                            <select class="form-control" required>
                                                <option value="">请选择</option>
                                                <option value="US">美国</option>
                                                <option value="GB">英国</option>
                                                <option value="HK">香港</option>
                                                <option value="SG">新加坡</option>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>卡账户币种
                                                <span class="label-en">card-account ccy</span>
                                            </label>
                                            <select class="form-control" required>
                                                <option value="">请选择</option>
                                                <option value="USD">USD</option>
                                                <option value="EUR">EUR</option>
                                                <option value="GBP">GBP</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>资金模式
                                                <span class="label-en">funding_model</span>
                                            </label>
                                            <select class="form-control" required>
                                                <option value="">请选择</option>
                                                <option value="Programme Managed">Programme Managed（项目管理）</option>
                                                <option value="Cardholder Managed">Cardholder Managed（持卡人管理）</option>
                                            </select>
                                            <div class="form-hint">PM = 钱是企业的，企业说了算；CM = 钱到卡上就是持卡人的</div>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>卡类别
                                                <span class="label-en">Card Programme Type</span>
                                            </label>
                                            <select class="form-control" required>
                                                <option value="">请选择</option>
                                                <option value="Corporate">Corporate（企业卡）</option>
                                                <option value="Consumer">Consumer（个人卡）</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">
                                            <span class="required">*</span>卡有效期
                                            <span class="label-en">Card Validity Period</span>
                                        </label>
                                        <input type="text" class="form-control" placeholder="如：3 years" required>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 步骤按钮 -->
                        <div class="step-actions">
                            <button type="button" class="btn btn-default" onclick="backToBinList()">取消</button>
                            <div>
                                <button type="button" class="btn btn-default" onclick="saveBinDraft()">保存草稿</button>
                                <button type="button" class="btn btn-primary" onclick="nextStep(1)">保存并下一步</button>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 2: 卡账户能力 -->
                    <div class="step-content" data-step="2">
                        <div class="card">
                            <div class="card-title">2. 卡账户能力</div>
                            
                            <div class="bin-item" data-bin-index="1">
                                <!-- 1.2 卡账户能力 -->
                                <div class="form-section">
                                    <div class="form-section-title">1.2 卡账户能力</div>
                                    
                                    <div class="form-group">
                                        <label class="form-label">
                                            <span class="required">*</span>卡产品类型
                                            <span class="label-en">Card Product Type</span>
                                        </label>
                                        <select class="form-control" required>
                                            <option value="Prepaid">Prepaid（预付卡）</option>
                                            <option value="Credit" disabled>Credit（信用卡 - 下期）</option>
                                            <option value="Deferred Credit" disabled>Deferred Credit（延期信用卡 - 下期）</option>
                                        </select>
                                        <div class="form-hint">本期仅支持 Prepaid</div>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">
                                            <span class="required">*</span>支持的卡片类型
                                            <span class="label-en">Supported Card Types</span>
                                        </label>
                                        <div class="checkbox-group">
                                            <label class="checkbox-item">
                                                <input type="checkbox" value="Standard" checked> 普通卡（Standard Card）
                                            </label>
                                            <label class="checkbox-item">
                                                <input type="checkbox" value="Shared" onchange="toggleSharedCardLimit(this)"> 共享卡（Shared Card）
                                            </label>
                                        </div>
                                        <div class="form-hint">可同时支持普通卡和共享卡，至少选择一种</div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group shared-card-limit" style="display:none;">
                                            <label class="form-label">
                                                <span class="required">*</span>共享卡账户最大数量
                                                <span class="label-en">shared account max cards</span>
                                            </label>
                                            <input type="number" class="form-control" placeholder="如：10" min="1">
                                            <div class="form-hint">单个共享卡账户下可挂载的最大卡片数量</div>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>转入币种
                                                <span class="label-en">recharge ccy-default</span>
                                            </label>
                                            <div class="multi-select-wrapper">
                                                <div class="multi-select-input" onclick="toggleMultiSelect(this, 'rechargeCcy')">
                                                    <span class="multi-select-placeholder">请选择转入币种</span>
                                                </div>
                                                <div class="multi-select-dropdown" id="rechargeCcy">
                                                    <div class="multi-select-search">
                                                        <input type="text" placeholder="搜索币种..." onkeyup="filterMultiSelect(this)">
                                                    </div>
                                                    <div class="multi-select-options">
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'USD')">
                                                            <input type="checkbox"><span>USD - 美元</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'EUR')">
                                                            <input type="checkbox"><span>EUR - 欧元</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'GBP')">
                                                            <input type="checkbox"><span>GBP - 英镑</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'HKD')">
                                                            <input type="checkbox"><span>HKD - 港币</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'SGD')">
                                                            <input type="checkbox"><span>SGD - 新加坡元</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'USDT')">
                                                            <input type="checkbox"><span>USDT - 泰达币</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'USDC')">
                                                            <input type="checkbox"><span>USDC - USD Coin</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 步骤按钮 -->
                        <div class="step-actions">
                            <button type="button" class="btn btn-default" onclick="prevStep(2)">上一步</button>
                            <div>
                                <button type="button" class="btn btn-default" onclick="saveBinDraft()">保存草稿</button>
                                <button type="button" class="btn btn-primary" onclick="nextStep(2)">保存并下一步</button>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 3: 交易能力 -->
                    <div class="step-content" data-step="3">
                        <div class="card">
                            <div class="card-title">3. 交易能力</div>
                            
                            <div class="bin-item" data-bin-index="1">
                                <!-- 1.3 交易能力 -->
                                <div class="form-section">
                                    <div class="form-section-title">1.3 交易能力</div>
                                    
                                    <div class="form-group">
                                        <label class="form-label">
                                            <span class="required">*</span>交易受理渠道
                                            <span class="label-en">transaction acceptance channel</span>
                                        </label>
                                        <div class="checkbox-group">
                                            <label class="checkbox-item">
                                                <input type="checkbox" value="ATM"> ATM
                                            </label>
                                            <label class="checkbox-item">
                                                <input type="checkbox" value="POS"> POS
                                            </label>
                                            <label class="checkbox-item">
                                                <input type="checkbox" value="Online"> 线上
                                            </label>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>卡消费次数
                                                <span class="label-en">card usage type</span>
                                            </label>
                                            <select class="form-control" onchange="toggleUsageType(this)" required>
                                                <option value="">请选择</option>
                                                <option value="Single-use">Single-use（单次）</option>
                                                <option value="Multi-use">Multi-use（多次）</option>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>授权模式
                                                <span class="label-en">authorization_mode</span>
                                            </label>
                                            <select class="form-control" required>
                                                <option value="">请选择</option>
                                                <option value="Real-time">Real-time（实时授权）</option>
                                                <option value="Standard">Standard（事后同步）</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>授权浮动
                                                <span class="label-en">auth-padding enable</span>
                                            </label>
                                            <select class="form-control" onchange="toggleAuthPadding(this)" required>
                                                <option value="">请选择</option>
                                                <option value="允许">允许</option>
                                                <option value="不允许">不允许</option>
                                            </select>
                                        </div>

                                        <div class="form-group auth-padding-value" style="display:none;">
                                            <label class="form-label">
                                                <span class="required">*</span>授权浮动值
                                                <span class="label-en">auth-padding value</span>
                                            </label>
                                            <input type="number" class="form-control" placeholder="如：5, 10, 15" min="0" max="100" step="0.1">
                                            <div class="form-hint">浮动比例（%）</div>
                                        </div>
                                    </div>

                                    <div class="subsection">
                                        <div class="subsection-title">3DS 配置</div>
                                        
                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>3DS 开关
                                                <span class="label-en">3ds_enabled</span>
                                            </label>
                                            <div class="radio-group">
                                                <label class="radio-item">
                                                    <input type="radio" name="3ds_enabled" value="Enabled" onchange="toggle3DS(this)"> Enabled
                                                </label>
                                                <label class="radio-item">
                                                    <input type="radio" name="3ds_enabled" value="Disabled" onchange="toggle3DS(this)" checked> Disabled
                                                </label>
                                            </div>
                                        </div>

                                        <div class="3ds-config" style="display:none;">
                                            <div class="form-group">
                                                <label class="form-label">
                                                    <span class="required">*</span>3DS 默认挑战策略
                                                    <span class="label-en">3ds_default_challenge_policy</span>
                                                </label>
                                                <select class="form-control">
                                                    <option value="">请选择</option>
                                                    <option value="Prefer Frictionless">Prefer Frictionless</option>
                                                    <option value="Prefer Challenge">Prefer Challenge</option>
                                                    <option value="Always Challenge">Always Challenge</option>
                                                </select>
                                            </div>

                                            <div class="form-group">
                                                <label class="form-label">
                                                    <span class="required">*</span>3DS 挑战方式
                                                    <span class="label-en">3ds_challenge_method</span>
                                                </label>
                                                <div class="checkbox-group">
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="OTP"> OTP（一次性验证码）
                                                    </label>
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="Static Password"> Static Password（静态密码）
                                                    </label>
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="Out-of-Band"> Out-of-Band（APP推送/邮件）
                                                    </label>
                                                </div>
                                            </div>

                                            <div class="form-group">
                                                <label class="form-label">
                                                    <span class="required">*</span>3DS 通知递送
                                                    <span class="label-en">3ds_notification_delivery</span>
                                                </label>
                                                <select class="form-control">
                                                    <option value="">请选择</option>
                                                    <option value="Direct to Cardholder">Direct to Cardholder（ACS直接发给持卡人）</option>
                                                    <option value="Webhook to Merchant">Webhook to Merchant（回调商户）</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 步骤按钮 -->
                        <div class="step-actions">
                            <button type="button" class="btn btn-default" onclick="prevStep(3)">上一步</button>
                            <div>
                                <button type="button" class="btn btn-default" onclick="saveBinDraft()">保存草稿</button>
                                <button type="button" class="btn btn-primary" onclick="nextStep(3)">保存并下一步</button>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 4: 卡限制配置 -->
                    <div class="step-content" data-step="4">
                        <div class="card">
                            <div class="card-title">4. 卡限制配置（Card Limits）</div>
                            
                            <div class="bin-item" data-bin-index="1">
                                <!-- 1.4 卡限制配置 -->
                                <div class="form-section">
                                    <div class="form-section-title">1.4 卡限制配置（Card Limits）</div>
                                    
                                    <!-- 1.4.1 卡片数量限制 -->
                                    <div class="subsection">
                                        <div class="subsection-title">1.4.1 卡片数量限制</div>
                                        
                                        <div class="form-row-3">
                                            <div class="form-group">
                                                <label class="form-label">单商户最大卡数量 <span class="label-en">card limit-per merchant</span></label>
                                                <input type="number" class="form-control" placeholder="如：100" min="0">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">单日开卡数量限制 <span class="label-en">card limit-daily</span></label>
                                                <input type="number" class="form-control" placeholder="如：10" min="0">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">单月开卡数量限制 <span class="label-en">card limit-monthly</span></label>
                                                <input type="number" class="form-control" placeholder="如：50" min="0">
                                            </div>
                                        </div>
                                        <div class="form-row-3">
                                            <div class="form-group">
                                                <label class="form-label">单年开卡数量限制 <span class="label-en">card limit-yearly</span></label>
                                                <input type="number" class="form-control" placeholder="如：500" min="0">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">累计开卡数量限制 <span class="label-en">card limit-total</span></label>
                                                <input type="number" class="form-control" placeholder="如：1000" min="0">
                                            </div>
                                        </div>
                                        <div class="form-hint">校验规则：单日 ≤ 单月 ≤ 单年 ≤ 累计 ≤ 单商户最大</div>
                                    </div>

                                    <!-- 1.4.2 转入/转出限额 -->
                                    <div class="subsection">
                                        <div class="subsection-title">1.4.2 转入/转出限额</div>
                                        
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label class="form-label">单次转入最小金额 <span class="label-en">recharge limit-min</span></label>
                                                <input type="number" class="form-control" placeholder="如：1 USD" min="0" step="0.01">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">单次转入最大金额 <span class="label-en">recharge limit-max</span></label>
                                                <input type="number" class="form-control" placeholder="如：50000 USD" min="0" step="0.01">
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label class="form-label">单次转出最小金额 <span class="label-en">withdraw limit-min</span></label>
                                                <input type="number" class="form-control" placeholder="如：1 USD" min="0" step="0.01">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">单次转出最大金额 <span class="label-en">withdraw limit-max</span></label>
                                                <input type="number" class="form-control" placeholder="如：50000 USD" min="0" step="0.01">
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 1.4.3 交易消费限额 -->
                                    <div class="subsection">
                                        <div class="subsection-title">1.4.3 交易消费限额</div>
                                        
                                        <div class="limit-list">
                                            <!-- 单笔限额 -->
                                            <div class="limit-item">
                                                <div class="limit-item-header">
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="per_transaction" onchange="toggleLimitConfig(this)" checked>
                                                        <span class="limit-name">单笔限额 <span class="label-en">PER_TRANSACTION</span></span>
                                                    </label>
                                                </div>
                                                <div class="limit-item-config">
                                                    <div class="limit-config-row">
                                                        <div class="limit-input-group">
                                                            <input type="number" class="form-control" placeholder="输入限额" min="0" step="0.01">
                                                            <select class="form-control limit-currency">
                                                                <option value="USD">USD</option>
                                                                <option value="EUR">EUR</option>
                                                                <option value="GBP">GBP</option>
                                                            </select>
                                                        </div>
                                                        <div class="limit-hint">单笔交易的最大金额</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 单日限额 -->
                                            <div class="limit-item">
                                                <div class="limit-item-header">
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="daily" onchange="toggleLimitConfig(this)" checked>
                                                        <span class="limit-name">单日限额 <span class="label-en">DAILY</span></span>
                                                    </label>
                                                </div>
                                                <div class="limit-item-config">
                                                    <div class="limit-config-row">
                                                        <div class="limit-input-group">
                                                            <input type="number" class="form-control" placeholder="输入限额" min="0" step="0.01">
                                                            <select class="form-control limit-currency">
                                                                <option value="USD">USD</option>
                                                                <option value="EUR">EUR</option>
                                                                <option value="GBP">GBP</option>
                                                            </select>
                                                        </div>
                                                        <div class="limit-hint">每日累计交易的最大金额</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 单周限额 -->
                                            <div class="limit-item">
                                                <div class="limit-item-header">
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="weekly" onchange="toggleLimitConfig(this)">
                                                        <span class="limit-name">单周限额 <span class="label-en">WEEKLY</span></span>
                                                    </label>
                                                </div>
                                                <div class="limit-item-config" style="display:none;">
                                                    <div class="limit-config-row">
                                                        <div class="limit-input-group">
                                                            <input type="number" class="form-control" placeholder="输入限额" min="0" step="0.01">
                                                            <select class="form-control limit-currency">
                                                                <option value="USD">USD</option>
                                                                <option value="EUR">EUR</option>
                                                                <option value="GBP">GBP</option>
                                                            </select>
                                                        </div>
                                                        <div class="limit-hint">每周累计交易的最大金额</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 单月限额 -->
                                            <div class="limit-item">
                                                <div class="limit-item-header">
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="monthly" onchange="toggleLimitConfig(this)" checked>
                                                        <span class="limit-name">单月限额 <span class="label-en">MONTHLY</span></span>
                                                    </label>
                                                </div>
                                                <div class="limit-item-config">
                                                    <div class="limit-config-row">
                                                        <div class="limit-input-group">
                                                            <input type="number" class="form-control" placeholder="输入限额" min="0" step="0.01">
                                                            <select class="form-control limit-currency">
                                                                <option value="USD">USD</option>
                                                                <option value="EUR">EUR</option>
                                                                <option value="GBP">GBP</option>
                                                            </select>
                                                        </div>
                                                        <div class="limit-hint">每月累计交易的最大金额</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 单年限额 -->
                                            <div class="limit-item">
                                                <div class="limit-item-header">
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="yearly" onchange="toggleLimitConfig(this)">
                                                        <span class="limit-name">单年限额 <span class="label-en">YEARLY</span></span>
                                                    </label>
                                                </div>
                                                <div class="limit-item-config" style="display:none;">
                                                    <div class="limit-config-row">
                                                        <div class="limit-input-group">
                                                            <input type="number" class="form-control" placeholder="输入限额" min="0" step="0.01">
                                                            <select class="form-control limit-currency">
                                                                <option value="USD">USD</option>
                                                                <option value="EUR">EUR</option>
                                                                <option value="GBP">GBP</option>
                                                            </select>
                                                        </div>
                                                        <div class="limit-hint">每年累计交易的最大金额</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 单卡累计限额 -->
                                            <div class="limit-item">
                                                <div class="limit-item-header">
                                                    <label class="checkbox-item">
                                                        <input type="checkbox" value="percard" onchange="toggleLimitConfig(this)" checked>
                                                        <span class="limit-name">单卡累计限额 <span class="label-en">PER CARD</span></span>
                                                    </label>
                                                </div>
                                                <div class="limit-item-config">
                                                    <div class="limit-config-row">
                                                        <div class="limit-input-group">
                                                            <input type="number" class="form-control" placeholder="输入限额" min="0" step="0.01">
                                                            <select class="form-control limit-currency">
                                                                <option value="USD">USD</option>
                                                                <option value="EUR">EUR</option>
                                                                <option value="GBP">GBP</option>
                                                            </select>
                                                        </div>
                                                        <div class="limit-hint">单卡生命周期内累计交易的最大金额</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 1.4.4 交易次数限制 -->
                                    <div class="subsection">
                                        <div class="subsection-title">1.4.4 交易次数限制</div>
                                        
                                        <div class="form-row-3">
                                            <div class="form-group">
                                                <label class="form-label">交易次数上限 <span class="label-en">allowed_transaction_count</span></label>
                                                <input type="number" class="form-control transaction-count-limit" placeholder="如：100" min="1">
                                                <div class="form-hint">单次消费时固定为1</div>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">单日交易次数限制 <span class="label-en">daily</span></label>
                                                <input type="number" class="form-control" placeholder="如：10" min="0">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">单月交易次数限制 <span class="label-en">monthly</span></label>
                                                <input type="number" class="form-control" placeholder="如：100" min="0">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 步骤按钮 -->
                        <div class="step-actions">
                            <button type="button" class="btn btn-default" onclick="prevStep(4)">上一步</button>
                            <div>
                                <button type="button" class="btn btn-default" onclick="saveBinDraft()">保存草稿</button>
                                <button type="button" class="btn btn-primary" onclick="nextStep(4)">保存并下一步</button>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 5: 风控能力 -->
                    <div class="step-content" data-step="5">
                        <div class="card">
                            <div class="card-title">5. 风控能力</div>
                            
                            <div class="bin-item" data-bin-index="1">
                                <!-- 1.5 风控能力 -->
                                <div class="form-section">
                                    <div class="form-section-title">1.5 风控能力</div>
                                    
                                    <div class="subsection">
                                        <div class="subsection-title">MCC 控制</div>
                                        
                                        <div class="form-group">
                                            <label class="form-label">MCC 控制模式 <span class="label-en">MCC CONTROL MODE</span></label>
                                            <div class="radio-group">
                                                <label class="radio-item">
                                                    <input type="radio" name="mcc_mode" value="" checked onchange="toggleMccMode(this)"> 不限制
                                                </label>
                                                <label class="radio-item">
                                                    <input type="radio" name="mcc_mode" value="Whitelist" onchange="toggleMccMode(this)"> 正向选择（白名单）
                                                </label>
                                                <label class="radio-item">
                                                    <input type="radio" name="mcc_mode" value="Blacklist" onchange="toggleMccMode(this)"> 反向选择（黑名单）
                                                </label>
                                            </div>
                                            <div class="form-hint">正向选择=只允许白名单内的MCC；反向选择=禁止黑名单内的MCC</div>
                                        </div>

                                        <div class="form-group mcc-whitelist" style="display:none;">
                                            <label class="form-label"><span class="required">*</span>MCC 白名单 <span class="label-en">MCC WHITELIST</span></label>
                                            <input type="text" class="form-control" placeholder="如：5411, 5812, 7311（逗号分隔）">
                                            <div class="form-hint">只允许这些商户类别码的交易</div>
                                        </div>

                                        <div class="form-group mcc-blacklist" style="display:none;">
                                            <label class="form-label"><span class="required">*</span>MCC 黑名单 <span class="label-en">MCC BLACKLIST</span></label>
                                            <input type="text" class="form-control" placeholder="如：7995（赌博）, 6012（金融）">
                                            <div class="form-hint">禁止这些商户类别码的交易</div>
                                        </div>
                                    </div>

                                    <div class="subsection">
                                        <div class="subsection-title">地区控制</div>
                                        
                                        <div class="form-group">
                                            <label class="form-label">地区控制模式 <span class="label-en">REGION CONTROL MODE</span></label>
                                            <div class="radio-group">
                                                <label class="radio-item">
                                                    <input type="radio" name="region_mode" value="" checked onchange="toggleRegionMode(this)"> 不限制
                                                </label>
                                                <label class="radio-item">
                                                    <input type="radio" name="region_mode" value="Accepted" onchange="toggleRegionMode(this)"> 正向选择（支持）
                                                </label>
                                                <label class="radio-item">
                                                    <input type="radio" name="region_mode" value="Restricted" onchange="toggleRegionMode(this)"> 反向选择（不支持）
                                                </label>
                                            </div>
                                            <div class="form-hint">正向选择=只允许支持地区的交易；反向选择=禁止不支持地区的交易</div>
                                        </div>

                                        <div class="form-group region-accepted" style="display:none;">
                                            <label class="form-label"><span class="required">*</span>支持业务地区 <span class="label-en">ACCEPTED REGION</span></label>
                                            <div class="multi-select-wrapper">
                                                <div class="multi-select-input" onclick="toggleMultiSelect(this, 'acceptedRegion')">
                                                    <span class="multi-select-placeholder">请选择支持的国家/地区</span>
                                                </div>
                                                <div class="multi-select-dropdown" id="acceptedRegion">
                                                    <div class="multi-select-search">
                                                        <input type="text" placeholder="搜索国家/地区..." onkeyup="filterMultiSelect(this)">
                                                    </div>
                                                    <div class="multi-select-options">
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'US')">
                                                            <input type="checkbox"><span>US - 美国</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'GB')">
                                                            <input type="checkbox"><span>GB - 英国</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'HK')">
                                                            <input type="checkbox"><span>HK - 香港</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'SG')">
                                                            <input type="checkbox"><span>SG - 新加坡</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'CN')">
                                                            <input type="checkbox"><span>CN - 中国大陆</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'JP')">
                                                            <input type="checkbox"><span>JP - 日本</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'AU')">
                                                            <input type="checkbox"><span>AU - 澳大利亚</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'CA')">
                                                            <input type="checkbox"><span>CA - 加拿大</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'FR')">
                                                            <input type="checkbox"><span>FR - 法国</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'DE')">
                                                            <input type="checkbox"><span>DE - 德国</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'IT')">
                                                            <input type="checkbox"><span>IT - 意大利</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'ES')">
                                                            <input type="checkbox"><span>ES - 西班牙</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'KR')">
                                                            <input type="checkbox"><span>KR - 韩国</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'TH')">
                                                            <input type="checkbox"><span>TH - 泰国</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'MY')">
                                                            <input type="checkbox"><span>MY - 马来西亚</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'ID')">
                                                            <input type="checkbox"><span>ID - 印度尼西亚</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'VN')">
                                                            <input type="checkbox"><span>VN - 越南</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'PH')">
                                                            <input type="checkbox"><span>PH - 菲律宾</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-hint">只允许这些国家/地区的交易</div>
                                        </div>

                                        <div class="form-group region-restricted" style="display:none;">
                                            <label class="form-label"><span class="required">*</span>不支持业务地区 <span class="label-en">RESTRICTED REGION</span></label>
                                            <div class="multi-select-wrapper">
                                                <div class="multi-select-input" onclick="toggleMultiSelect(this, 'restrictedRegion')">
                                                    <span class="multi-select-placeholder">请选择禁止的国家/地区</span>
                                                </div>
                                                <div class="multi-select-dropdown" id="restrictedRegion">
                                                    <div class="multi-select-search">
                                                        <input type="text" placeholder="搜索国家/地区..." onkeyup="filterMultiSelect(this)">
                                                    </div>
                                                    <div class="multi-select-options">
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'IR')">
                                                            <input type="checkbox"><span>IR - 伊朗</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'KP')">
                                                            <input type="checkbox"><span>KP - 朝鲜</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'CU')">
                                                            <input type="checkbox"><span>CU - 古巴</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'SY')">
                                                            <input type="checkbox"><span>SY - 叙利亚</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'SD')">
                                                            <input type="checkbox"><span>SD - 苏丹</span>
                                                        </div>
                                                        <div class="multi-select-option" onclick="selectMultiOption(this, 'VE')">
                                                            <input type="checkbox"><span>VE - 委内瑞拉</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-hint">禁止这些国家/地区的交易</div>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">客户主体限制 <span class="label-en">ENTITY RESTRICTIONS</span></label>
                                        <div id="entityRestrictions">
                                            <div class="entity-restriction-item" style="display: flex; gap: 16px; margin-bottom: 12px; align-items: flex-end;">
                                                <div style="flex: 1;">
                                                    <label style="display: block; margin-bottom: 4px; font-size: 12px;">国家/地区</label>
                                                    <select class="form-control">
                                                        <option value="">请选择</option>
                                                        <option value="CN">中国大陆</option>
                                                        <option value="US">美国</option>
                                                        <option value="GB">英国</option>
                                                        <option value="HK">香港</option>
                                                        <option value="SG">新加坡</option>
                                                    </select>
                                                </div>
                                                <div style="flex: 1;">
                                                    <label style="display: block; margin-bottom: 4px; font-size: 12px;">主体类型</label>
                                                    <div class="checkbox-group">
                                                        <label class="checkbox-item"><input type="checkbox" value="Individual"> 个人</label>
                                                        <label class="checkbox-item"><input type="checkbox" value="Enterprise"> 企业</label>
                                                    </div>
                                                </div>
                                                <button type="button" class="btn btn-default" onclick="removeEntityRestriction(this)">删除</button>
                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-default" onclick="addEntityRestriction()">+ 添加组合</button>
                                        <div class="form-hint">示例：中国大陆支持个人和企业，其他国家只支持企业</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 步骤按钮 -->
                        <div class="step-actions">
                            <button type="button" class="btn btn-default" onclick="prevStep(5)">上一步</button>
                            <div>
                                <button type="button" class="btn btn-default" onclick="saveBinDraft()">保存草稿</button>
                                <button type="button" class="btn btn-primary" onclick="nextStep(5)">保存并下一步</button>
                            </div>
                        </div>
                    </div>

                    <!-- 步骤 6: 持卡人要求 -->
                    <div class="step-content" data-step="6">
                        <div class="card">
                            <div class="card-title">6. 持卡人要求</div>
                            
                            <div class="bin-item" data-bin-index="1">
                                <!-- 1.6 持卡人要求 -->
                                <div class="form-section">
                                    <div class="form-section-title">1.6 持卡人要求</div>
                                    
                                    <div class="form-group">
                                        <label class="form-label">
                                            <span class="required">*</span>是否需要持卡人
                                            <span class="label-en">cardholder needed</span>
                                        </label>
                                        <div class="radio-group">
                                            <label class="radio-item">
                                                <input type="radio" name="cardholder_needed" value="Yes" onchange="toggleCardholderInfo(this)"> Yes
                                            </label>
                                            <label class="radio-item">
                                                <input type="radio" name="cardholder_needed" value="No" onchange="toggleCardholderInfo(this)" checked> No
                                            </label>
                                        </div>
                                    </div>

                                    <div class="cardholder-info" style="display:none;">
                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>持卡人类型
                                                <span class="label-en">cardholder 类型</span>
                                            </label>
                                            <select class="form-control">
                                                <option value="">请选择</option>
                                                <option value="Individual">Individual（个人）</option>
                                                <option value="Enterprise">Enterprise（企业）</option>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">
                                                <span class="required">*</span>持卡人地区
                                                <span class="label-en">holder regions</span>
                                            </label>
                                            <div class="checkbox-group">
                                                <label class="checkbox-item"><input type="checkbox" value="US"> 美国</label>
                                                <label class="checkbox-item"><input type="checkbox" value="GB"> 英国</label>
                                                <label class="checkbox-item"><input type="checkbox" value="HK"> 香港</label>
                                                <label class="checkbox-item"><input type="checkbox" value="SG"> 新加坡</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 步骤按钮 -->
                        <div class="step-actions">
                            <button type="button" class="btn btn-default" onclick="prevStep(6)">上一步</button>
                            <div>
                                <button type="button" class="btn btn-default" onclick="saveBinDraft()">保存草稿</button>
                                <button type="submit" class="btn btn-primary">保存并启用</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- 服务商详情抽屉 -->
    <div class="drawer-overlay" id="spDetailOverlay" onclick="closeDrawer('spDetail')"></div>
    <div class="drawer" id="spDetailDrawer">
        <div class="drawer-header">
            <div class="drawer-title">服务商详情</div>
            <div class="drawer-close" onclick="closeDrawer('spDetail')">×</div>
        </div>
        <div class="drawer-body">
            <div class="form-group">
                <label class="form-label">服务商ID</label>
                <div id="sp-id">SP001</div>
            </div>
            <div class="form-group">
                <label class="form-label">服务商名称</label>
                <div id="sp-name">GlobalCard Solutions</div>
            </div>
            <div class="form-group">
                <label class="form-label">所在地区</label>
                <div id="sp-region">香港</div>
            </div>
            <div class="form-group">
                <label class="form-label">提供产品</label>
                <div id="sp-products">
                    <span class="tag tag-blue">VCC发卡</span>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">状态</label>
                <div><span class="status-badge status-active">启用</span></div>
            </div>
            <div class="form-group">
                <label class="form-label">创建时间</label>
                <div>2026-01-15 10:30:00</div>
            </div>
        </div>
    </div>

    <!-- 产品选择弹层 -->
    <div class="modal-overlay" id="productSelectModal">
        <div class="modal">
            <div class="modal-header">
                <div class="modal-title">选择产品类型</div>
            </div>
            <div class="modal-body">
                <div class="product-card" onclick="selectProduct('vcc')">
                    <div class="product-card-header">
                        <div class="product-icon">💳</div>
                        <div>
                            <div class="product-card-title">VCC（虚拟卡）</div>
                        </div>
                    </div>
                    <div class="product-card-desc">
                        虚拟卡发卡产品，支持线上消费、广告投放、订阅支付等场景。配置包括卡 Bin、交易能力、限额控制、风控规则等。
                    </div>
                </div>

                <div class="product-card" onclick="selectProduct('crypto')">
                    <div class="product-card-header">
                        <div class="product-icon crypto">₿</div>
                        <div>
                            <div class="product-card-title">数币收单</div>
                        </div>
                    </div>
                    <div class="product-card-desc">
                        数字货币收单产品，支持 USDT、USDC 等主流稳定币收款。配置包括支持币种、收款地址、结算规则等。
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" onclick="closeProductSelectModal()">取消</button>
            </div>
        </div>
    </div>

    <script>
        // 页面切换
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(page => page.classList.add('hidden'));
            document.getElementById(pageId).classList.remove('hidden');
            
            document.querySelectorAll('.menu-item').forEach(item => item.classList.remove('active'));
            event.target.classList.add('active');
        }

        // 显示产品类型选择
        function showProductTypeSelect() {
            document.getElementById('productSelectModal').classList.add('active');
        }

        // 关闭产品选择弹层
        function closeProductSelectModal() {
            document.getElementById('productSelectModal').classList.remove('active');
        }

        // 选择产品
        function selectProduct(productType) {
            closeProductSelectModal();
            if (productType === 'vcc') {
                showVccBinList();
            } else if (productType === 'crypto') {
                alert('数币收单产品配置页面开发中...');
            }
        }

        // 显示 VCC Bin 列表
        function showVccBinList() {
            document.querySelectorAll('.page').forEach(page => page.classList.add('hidden'));
            document.getElementById('vcc-bin-list').classList.remove('hidden');
        }

        // 返回产品列表
        function backToProductList() {
            document.querySelectorAll('.page').forEach(page => page.classList.add('hidden'));
            document.getElementById('sp-product-list').classList.remove('hidden');
        }

        // 显示添加 Bin 页面
        function showAddBinPage() {
            document.getElementById('binConfigTitle').textContent = '添加 Bin 配置';
            document.getElementById('vccBinForm').reset();
            document.querySelectorAll('.page').forEach(page => page.classList.add('hidden'));
            document.getElementById('vcc-bin-config').classList.remove('hidden');
        }

        // 编辑 Bin 配置
        function editBinConfig(binNumber) {
            document.getElementById('binConfigTitle').textContent = '编辑 Bin 配置 - ' + binNumber;
            // 这里可以加载该 Bin 的数据填充表单
            document.querySelectorAll('.page').forEach(page => page.classList.add('hidden'));
            document.getElementById('vcc-bin-config').classList.remove('hidden');
        }

        // 返回 Bin 列表
        function backToBinList() {
            if (confirm('确定要返回吗？未保存的数据将丢失。')) {
                showVccBinList();
            }
        }

        // 查看产品详情（从产品列表进入 Bin 列表）
        function showProductDetail(productCode) {
            if (productCode.startsWith('VCC_')) {
                showVccBinList();
            }
        }

        // 编辑产品（从产品列表进入 Bin 列表）
        function editProduct(productCode) {
            if (productCode.startsWith('VCC_')) {
                showVccBinList();
            }
        }

        // 显示服务商详情
        function showSpDetail(spId) {
            document.getElementById('spDetailOverlay').classList.add('active');
            document.getElementById('spDetailDrawer').classList.add('active');
        }

        // 关闭抽屉
        function closeDrawer(type) {
            if (type === 'spDetail') {
                document.getElementById('spDetailOverlay').classList.remove('active');
                document.getElementById('spDetailDrawer').classList.remove('active');
            }
        }

        // 共享卡限制显示/隐藏
        function toggleSharedCardLimit(checkbox) {
            const formGroup = checkbox.closest('.form-group');
            const limitGroup = formGroup.parentElement.querySelector('.shared-card-limit');
            
            if (limitGroup) {
                if (checkbox.checked) {
                    limitGroup.style.display = 'block';
                    const input = limitGroup.querySelector('input');
                    if (input) input.required = true;
                } else {
                    limitGroup.style.display = 'none';
                    const input = limitGroup.querySelector('input');
                    if (input) input.required = false;
                }
            }
        }

        // 卡消费次数切换
        function toggleUsageType(select) {
            const transactionCountInput = document.querySelector('.transaction-count-limit');
            if (select.value === 'Single-use') {
                transactionCountInput.value = '1';
                transactionCountInput.disabled = true;
            } else {
                transactionCountInput.disabled = false;
                transactionCountInput.value = '';
            }
        }

        // 授权浮动切换
        function toggleAuthPadding(select) {
            const paddingValue = select.closest('.form-row').querySelector('.auth-padding-value');
            if (select.value === '允许') {
                paddingValue.style.display = 'block';
                paddingValue.querySelector('input').required = true;
            } else {
                paddingValue.style.display = 'none';
                paddingValue.querySelector('input').required = false;
            }
        }

        // 3DS 配置切换
        function toggle3DS(radio) {
            // 获取最近的 subsection 容器
            const subsection = radio.closest('.subsection');
            
            if (!subsection) {
                console.error('找不到 subsection 容器');
                return;
            }
            
            // 查找 3DS 配置区域
            const config = subsection.querySelector('.3ds-config');
            
            if (!config) {
                console.error('找不到 .3ds-config 元素');
                return;
            }
            
            console.log('3DS 开关切换:', radio.value);
            
            if (radio.value === 'Enabled') {
                config.style.display = 'block';
                // 设置必填
                const selects = config.querySelectorAll('select');
                console.log('找到的 select 元素数量:', selects.length);
                selects.forEach(s => s.required = true);
            } else {
                config.style.display = 'none';
                // 取消必填
                config.querySelectorAll('select').forEach(s => s.required = false);
            }
        }

        // 持卡人信息切换
        function toggleCardholderInfo(radio) {
            const info = document.querySelector('.cardholder-info');
            if (radio.value === 'Yes') {
                info.style.display = 'block';
                info.querySelectorAll('select').forEach(s => s.required = true);
            } else {
                info.style.display = 'none';
                info.querySelectorAll('select').forEach(s => s.required = false);
            }
        }

        // MCC 控制模式切换
        function toggleMccMode(radio) {
            const whitelist = document.querySelector('.mcc-whitelist');
            const blacklist = document.querySelector('.mcc-blacklist');
            
            if (radio.value === 'Whitelist') {
                whitelist.style.display = 'block';
                whitelist.querySelector('input').required = true;
                blacklist.style.display = 'none';
                blacklist.querySelector('input').required = false;
                blacklist.querySelector('input').value = '';
            } else if (radio.value === 'Blacklist') {
                blacklist.style.display = 'block';
                blacklist.querySelector('input').required = true;
                whitelist.style.display = 'none';
                whitelist.querySelector('input').required = false;
                whitelist.querySelector('input').value = '';
            } else {
                whitelist.style.display = 'none';
                blacklist.style.display = 'none';
                whitelist.querySelector('input').required = false;
                blacklist.querySelector('input').required = false;
                whitelist.querySelector('input').value = '';
                blacklist.querySelector('input').value = '';
            }
        }

        // 地区控制模式切换
        function toggleRegionMode(radio) {
            const accepted = document.querySelector('.region-accepted');
            const restricted = document.querySelector('.region-restricted');
            
            if (radio.value === 'Accepted') {
                accepted.style.display = 'block';
                accepted.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                    cb.closest('.form-group').style.display = 'block';
                });
                restricted.style.display = 'none';
                restricted.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                    cb.checked = false;
                });
            } else if (radio.value === 'Restricted') {
                restricted.style.display = 'block';
                restricted.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                    cb.closest('.form-group').style.display = 'block';
                });
                accepted.style.display = 'none';
                accepted.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                    cb.checked = false;
                });
            } else {
                accepted.style.display = 'none';
                restricted.style.display = 'none';
                accepted.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
                restricted.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
            }
        }

        // 添加客户主体限制组合
        function addEntityRestriction() {
            const container = document.getElementById('entityRestrictions');
            const newItem = container.querySelector('.entity-restriction-item').cloneNode(true);
            newItem.querySelectorAll('select, input').forEach(input => {
                input.value = '';
                if (input.type === 'checkbox') input.checked = false;
            });
            container.appendChild(newItem);
        }

        // 删除客户主体限制组合
        function removeEntityRestriction(btn) {
            const container = document.getElementById('entityRestrictions');
            if (container.querySelectorAll('.entity-restriction-item').length > 1) {
                btn.closest('.entity-restriction-item').remove();
            } else {
                alert('至少保留一个组合');
            }
        }

        // 切换限额配置显示
        function toggleLimitConfig(checkbox) {
            const limitItem = checkbox.closest('.limit-item');
            const config = limitItem.querySelector('.limit-item-config');
            
            if (config) {
                if (checkbox.checked) {
                    config.style.display = 'block';
                    // 设置必填
                    const inputs = config.querySelectorAll('input, select');
                    inputs.forEach(input => {
                        if (input.type !== 'checkbox') {
                            input.required = true;
                        }
                    });
                } else {
                    config.style.display = 'none';
                    // 取消必填并清空值
                    const inputs = config.querySelectorAll('input, select');
                    inputs.forEach(input => {
                        if (input.type !== 'checkbox') {
                            input.required = false;
                            if (input.tagName === 'INPUT') {
                                input.value = '';
                            }
                        }
                    });
                }
            }
        }

        // 保存 Bin 草稿
        function saveBinDraft() {
            alert('Bin 配置已保存为草稿');
            showVccBinList();
        }

        // 表单提交
        document.getElementById('vccBinForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Bin 配置保存成功！');
            showVccBinList();
        });

        // 多选组件逻辑
        let currentOpenDropdown = null;

        // 切换下拉框
        function toggleMultiSelect(inputEl, dropdownId) {
            const dropdown = document.getElementById(dropdownId);
            const isActive = dropdown.classList.contains('active');
            
            // 关闭其他下拉框
            if (currentOpenDropdown && currentOpenDropdown !== dropdown) {
                currentOpenDropdown.classList.remove('active');
                currentOpenDropdown.previousElementSibling.classList.remove('focused');
            }
            
            if (isActive) {
                dropdown.classList.remove('active');
                inputEl.classList.remove('focused');
                currentOpenDropdown = null;
            } else {
                dropdown.classList.add('active');
                inputEl.classList.add('focused');
                currentOpenDropdown = dropdown;
                // 聚焦搜索框
                const searchInput = dropdown.querySelector('.multi-select-search input');
                if (searchInput) {
                    setTimeout(() => searchInput.focus(), 100);
                }
            }
        }

        // 选择选项
        function selectMultiOption(optionEl, value) {
            event.stopPropagation();
            const checkbox = optionEl.querySelector('input[type="checkbox"]');
            checkbox.checked = !checkbox.checked;
            
            if (checkbox.checked) {
                optionEl.classList.add('selected');
            } else {
                optionEl.classList.remove('selected');
            }
            
            updateMultiSelectDisplay(optionEl);
        }

        // 更新显示
        function updateMultiSelectDisplay(optionEl) {
            const dropdown = optionEl.closest('.multi-select-dropdown');
            const wrapper = dropdown.closest('.multi-select-wrapper');
            const inputEl = wrapper.querySelector('.multi-select-input');
            const selectedOptions = dropdown.querySelectorAll('.multi-select-option.selected');
            
            // 清空现有标签
            inputEl.querySelectorAll('.multi-select-tag').forEach(tag => tag.remove());
            const placeholder = inputEl.querySelector('.multi-select-placeholder');
            
            if (selectedOptions.length > 0) {
                if (placeholder) placeholder.style.display = 'none';
                
                selectedOptions.forEach(option => {
                    const text = option.querySelector('span').textContent;
                    const value = option.getAttribute('onclick').match(/'([^']+)'/)[1];
                    
                    const tag = document.createElement('div');
                    tag.className = 'multi-select-tag';
                    tag.innerHTML = `
                        <span>${text}</span>
                        <span class="multi-select-tag-close" onclick="removeMultiSelectTag(event, '${value}', '${dropdown.id}')">×</span>
                    `;
                    inputEl.insertBefore(tag, placeholder);
                });
            } else {
                if (placeholder) placeholder.style.display = 'block';
            }
        }

        // 移除标签
        function removeMultiSelectTag(event, value, dropdownId) {
            event.stopPropagation();
            const dropdown = document.getElementById(dropdownId);
            const option = Array.from(dropdown.querySelectorAll('.multi-select-option')).find(opt => {
                return opt.getAttribute('onclick').includes(`'${value}'`);
            });
            
            if (option) {
                const checkbox = option.querySelector('input[type="checkbox"]');
                checkbox.checked = false;
                option.classList.remove('selected');
                updateMultiSelectDisplay(option);
            }
        }

        // 搜索过滤
        function filterMultiSelect(searchInput) {
            const searchText = searchInput.value.toLowerCase();
            const dropdown = searchInput.closest('.multi-select-dropdown');
            const options = dropdown.querySelectorAll('.multi-select-option');
            let hasVisible = false;
            
            options.forEach(option => {
                const text = option.querySelector('span').textContent.toLowerCase();
                if (text.includes(searchText)) {
                    option.style.display = 'flex';
                    hasVisible = true;
                } else {
                    option.style.display = 'none';
                }
            });
            
            // 显示/隐藏空状态
            let emptyEl = dropdown.querySelector('.multi-select-empty');
            if (!hasVisible) {
                if (!emptyEl) {
                    emptyEl = document.createElement('div');
                    emptyEl.className = 'multi-select-empty';
                    emptyEl.textContent = '无匹配结果';
                    dropdown.querySelector('.multi-select-options').appendChild(emptyEl);
                }
                emptyEl.style.display = 'block';
            } else if (emptyEl) {
                emptyEl.style.display = 'none';
            }
        }

        // 点击外部关闭下拉框
        document.addEventListener('click', function(e) {
            if (currentOpenDropdown && !e.target.closest('.multi-select-wrapper')) {
                currentOpenDropdown.classList.remove('active');
                currentOpenDropdown.previousElementSibling.classList.remove('focused');
                currentOpenDropdown = null;
            }
        });

        // 步骤切换逻辑
        let binFormData = {}; // 存储表单数据

        // 下一步
        function nextStep(currentStep) {
            // 保存当前步骤的数据
            saveCurrentStepData(currentStep);
            
            // 切换到下一步
            const nextStepNum = currentStep + 1;
            if (nextStepNum <= 6) {
                switchToStep(nextStepNum);
            }
        }

        // 上一步
        function prevStep(currentStep) {
            const prevStepNum = currentStep - 1;
            if (prevStepNum >= 1) {
                switchToStep(prevStepNum);
            }
        }

        // 切换步骤
        function switchToStep(stepNum) {
            // 隐藏所有步骤内容
            document.querySelectorAll('.step-content').forEach(content => {
                content.classList.remove('active');
            });
            
            // 显示目标步骤内容
            const targetContent = document.querySelector(`.step-content[data-step="${stepNum}"]`);
            if (targetContent) {
                targetContent.classList.add('active');
            }
            
            // 更新步骤导航状态
            document.querySelectorAll('.step').forEach((step, index) => {
                const stepNumber = index + 1;
                step.classList.remove('active', 'completed');
                
                if (stepNumber < stepNum) {
                    step.classList.add('completed');
                } else if (stepNumber === stepNum) {
                    step.classList.add('active');
                }
            });
            
            // 滚动到顶部
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // 保存当前步骤数据
        function saveCurrentStepData(step) {
            const stepContent = document.querySelector(`.step-content[data-step="${step}"]`);
            if (!stepContent) return;
            
            // 这里可以添加具体的数据收集逻辑
            // 例如：收集表单字段值，存储到 binFormData 对象中
            console.log(`保存步骤 ${step} 的数据`);
            
            // 示例：收集第一步的数据
            if (step === 1) {
                const binInput = stepContent.querySelector('input[placeholder*="53422618"]');
                if (binInput) {
                    binFormData.bin = binInput.value;
                }
            }
        }
    </script>
</body>
</html>
