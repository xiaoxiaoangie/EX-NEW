# ============================================================
# FIBD 智能助手 — 环境变量配置模板
# 复制为 .env 后填入实际值，.env 文件绝不入库
# ============================================================

# ---------- LLM 模型 ----------
LLM_PROVIDER=deepseek                     # deepseek / openai / azure_openai
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=deepseek-chat                   # deepseek-chat / gpt-4o / gpt-4o-mini
LLM_BASE_URL=https://api.deepseek.com/v1  # 可选，自定义 endpoint
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ---------- 新闻 & 资讯 API ----------
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx          # https://newsapi.org
GOOGLE_NEWS_API_KEY=                                   # 如使用 SerpAPI
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx           # https://serpapi.com
BING_NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx    # Azure Cognitive Services

# ---------- LinkedIn ----------
# 方式一：官方 API（推荐，需申请 Marketing Developer Platform）
LINKEDIN_CLIENT_ID=xxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxx
LINKEDIN_ACCESS_TOKEN=                    # OAuth2 获取，有效期60天
LINKEDIN_REFRESH_TOKEN=                   # 用于自动续期

# 方式二：第三方数据服务（备选，无需直接登录）
PROXYCURL_API_KEY=xxxxxxxxxxxxxxxx        # https://proxycurl.com (LinkedIn数据)
PHANTOMBUSTER_API_KEY=xxxxxxxxxxxxxxxx    # https://phantombuster.com

# ---------- Twitter / X ----------
# X API v2 (Essential/Basic/Pro tier)
TWITTER_BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- 邮件发送 ----------
# 方式一：AWS SES
AWS_SES_REGION=ap-southeast-1
AWS_SES_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
AWS_SES_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SES_FROM_EMAIL=bd@company.com
AWS_SES_FROM_NAME=FIBD Team

# 方式二：SMTP（备选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bd-outreach@company.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx        # App Password，非登录密码
SMTP_TLS=true

# ---------- 邮箱验证服务 ----------
ZEROBOUNCE_API_KEY=xxxxxxxxxxxxxxxx       # https://zerobounce.net
HUNTER_API_KEY=xxxxxxxxxxxxxxxx           # https://hunter.io (邮箱查找+验证)

# ---------- CRM 集成 ----------
CRM_PROVIDER=hubspot                      # hubspot / salesforce / custom
HUBSPOT_API_KEY=pat-xxxxxxxx-xxxx-xxxx
HUBSPOT_PORTAL_ID=12345678
# SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_REFRESH_TOKEN=

# ---------- 飞书 / Lark ----------
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_WEBHOOK_HIGH=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx   # 高优商机群
FEISHU_BOT_WEBHOOK_DAILY=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx  # 每日简报群
FEISHU_BOT_WEBHOOK_CHANNEL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx # 渠道需求群

# ---------- 数据库 ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bd_assistant
POSTGRES_USER=bd_app
POSTGRES_PASSWORD=xxxxxxxx

REDIS_URL=redis://localhost:6379/0        # 缓存 & 队列

# ---------- 向量数据库 ----------
VECTOR_DB_PROVIDER=milvus                 # milvus / pinecone / qdrant
MILVUS_HOST=localhost
MILVUS_PORT=19530
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# ---------- 代理 & 反爬 ----------
PROXY_ENABLED=true
PROXY_PROVIDER=brightdata                 # brightdata / smartproxy / oxylabs
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
PROXY_USER=brd-customer-xxxxx-zone-xxxxx
PROXY_PASSWORD=xxxxxxxx

# ---------- 日程预约 ----------
CALENDLY_API_KEY=xxxxxxxxxxxxxxxx
CALENDLY_EVENT_URL=https://calendly.com/fibd-team/30min

# ---------- 安全 ----------
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # 用于加密存储的凭证
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
